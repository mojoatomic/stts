        "multiplier": 3.0,
        "justification": "d|q-1AU|/dt: rate of perihelion approach to Earth orbit"
      },
      "W[20:22]": {
        "multiplier": 2.0,
        "justification": "d\u00b2q/dt\u00b2: acceleration of perihelion evolution"
      },
      "W[22:24]": {
        "multiplier": 2.0,
        "justification": "e-q, a-q correlation: coupled orbital evolution under perturbation"
      },
      "W[24:25]": {
        "multiplier": 3.0,
        "justification": "q linear trend: directional approach signal over window"
      },
      "W[25:26]": {
        "multiplier": 4.0,
        "justification": "late/early |q-1AU| ratio: most discriminating precursor feature"
      },
      "W[26:27]": {
        "multiplier": 0.2,
        "justification": "mean inclination: orbital geometry context, not approach signal"
      },
      "W[27:28]": {
        "multiplier": 1.0,
        "justification": "mean motion: neutral weight, included for completeness"
      },
      "W[28:30]": {
        "multiplier": 2.0,
        "justification": "time to perihelion: approach phase context"
      }
